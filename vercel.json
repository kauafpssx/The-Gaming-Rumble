{
  "framework": "vite",
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 20 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" }
  ]
}
